---
import '../styles/global.css';
import SeoHead from '../components/SeoHead.astro';

const repositoryUrl = 'https://github.com/SWHL/awesome-ios-url-schemes';
const newSchemeUrl = `${repositoryUrl}/issues/new?template=new-scheme.yml`;
const pageTitle = '使用教程 - iOS URL Scheme 查询、复制与反馈指南';
const pageDescription = '了解如何在 Awesome iOS URL Schemes 中搜索 App Scheme、复制测试、反馈可用性，并通过 GitHub Issue 提交新的 iOS URL Scheme。';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: '如何使用 Awesome iOS URL Schemes',
  description: pageDescription,
  inLanguage: 'zh-CN',
  step: [
    {
      '@type': 'HowToStep',
      name: '查找 Scheme',
      text: '在首页搜索 App、URL Scheme、Bundle ID 或用途，并使用视图与筛选器缩小范围。',
    },
    {
      '@type': 'HowToStep',
      name: '复制并测试',
      text: '复制 URL Scheme，在 iPhone 的 Safari、快捷指令或调试入口中打开测试。',
    },
    {
      '@type': 'HowToStep',
      name: '反馈可用或失效',
      text: '使用页面中的反馈按钮创建预填好的 GitHub Issue。',
    },
    {
      '@type': 'HowToStep',
      name: '提交新的 Scheme',
      text: '填写 App、URL Scheme、用途、验证状态和证据类型，提交后自动生成待审核 PR。',
    },
  ],
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <SeoHead title={pageTitle} description={pageDescription} path="/guide/" markdownPath="/guide.md" jsonLd={jsonLd} />
  </head>
  <body id="top">
    <header class="site-header">
      <a class="brand" href="../" aria-label="awesome-ios-url-schemes">
        <span class="brand-mark">⌘</span>
        <span>awesome-ios-url-schemes</span>
      </a>
      <div class="header-actions">
        <nav class="site-nav" aria-label="Primary">
          <a href="../guide/">教程</a>
          <a href="../sources/">参考</a>
          <a href="../#bundle-id-lookup">Bundle ID</a>
          <a href="../#schemes">索引</a>
          <a href={newSchemeUrl} rel="noreferrer">提交 Scheme</a>
          <a href={repositoryUrl} rel="noreferrer">GitHub</a>
        </nav>
        <div class="theme-switcher" aria-label="主题">
          <button class="theme-option" type="button" data-theme-option="light" aria-label="亮色" title="亮色">☀</button>
          <button class="theme-option" type="button" data-theme-option="dark" aria-label="暗色" title="暗色">☾</button>
          <button class="theme-option" type="button" data-theme-option="system" aria-label="跟随系统" title="跟随系统">◐</button>
        </div>
      </div>
    </header>

    <main>
      <section class="guide-hero" aria-labelledby="guide-title">
        <h1 id="guide-title">怎么用</h1>
        <p class="lede">查找、复制、验证、反馈，尽量控制在一次点击内完成。</p>
      </section>

      <section class="guide-page" aria-label="使用步骤">
        <article class="guide-step">
          <span class="step-index">1</span>
          <div>
            <h2>查找 Scheme</h2>
            <p>在首页搜索 App、URL Scheme、Bundle ID 或用途。也可以切换到按 App、按能力、全部列表三种视图。</p>
          </div>
        </article>

        <article class="guide-step">
          <span class="step-index">2</span>
          <div>
            <h2>复制并测试</h2>
            <p>点每条记录右侧的复制按钮，把 URL Scheme 粘到 iPhone 的 Safari、快捷指令或你的调试入口里打开。</p>
          </div>
        </article>

        <article class="guide-step">
          <span class="step-index">3</span>
          <div>
            <h2>反馈可用或失效</h2>
            <p>验证后点对勾表示可用，点叉表示失效。页面会打开预填好的 GitHub Issue，并自动带上对应 scheme。</p>
          </div>
        </article>

        <article class="guide-step">
          <span class="step-index">4</span>
          <div>
            <h2>提交新的 Scheme</h2>
            <p>点提交 Scheme，填写 App、URL Scheme 和用途。Issue 创建后会自动生成待审核 PR。</p>
            <a class="primary-action inline-action" href={newSchemeUrl} rel="noreferrer">提交 Scheme</a>
          </div>
        </article>
      </section>

      <section class="review-flow" aria-labelledby="review-title">
        <p class="eyebrow">Review</p>
        <h2 id="review-title">审核流程</h2>
        <div class="flow-row">
          <span>用户提交 Issue</span>
          <span>自动生成 PR</span>
          <span>维护者审核合并</span>
        </div>
      </section>
    </main>
    <a class="back-top" href="#top" aria-label="返回顶部" title="返回顶部">↑</a>
    <script>
      const themeButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.theme-option'));
      const systemTheme = window.matchMedia('(prefers-color-scheme: dark)');

      function resolveTheme(preference: string) {
        return preference === 'system' ? (systemTheme.matches ? 'dark' : 'light') : preference;
      }

      function setTheme(preference: string) {
        const nextPreference = ['light', 'dark', 'system'].includes(preference) ? preference : 'system';
        document.documentElement.dataset.theme = resolveTheme(nextPreference);
        document.documentElement.dataset.themePreference = nextPreference;
        localStorage.setItem('theme-preference', nextPreference);

        for (const button of themeButtons) {
          const active = button.dataset.themeOption === nextPreference;
          button.classList.toggle('is-active', active);
          button.setAttribute('aria-pressed', String(active));
        }
      }

      themeButtons.forEach((button) => {
        button.addEventListener('click', () => setTheme(button.dataset.themeOption || 'system'));
      });
      systemTheme.addEventListener('change', () => {
        if (document.documentElement.dataset.themePreference === 'system') setTheme('system');
      });
      setTheme(document.documentElement.dataset.themePreference || 'system');
    </script>
  </body>
</html>
